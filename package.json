{
	"name": "@projectwallace/format-css",
	"version": "3.0.2",
	"description": "Fast, small, zero-config library to format or minify CSS with basic rules.",
	"keywords": [
		"css",
		"format",
		"formatter",
		"prettier",
		"prettifier",
		"pretty",
		"print",
		"style",
		"stylesheet"
	],
	"homepage": "https://github.com/projectwallace/format-css",
	"license": "MIT",
	"author": "Bart Veneman <bart@projectwallace.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/format-css.git"
	},
	"bin": {
		"format-css": "./dist/cli.mjs"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest --coverage",
		"check": "tsc",
		"lint": "oxlint && oxfmt --check"
	},
	"dependencies": {
		"@projectwallace/css-parser": "~0.14.7"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^1.9.1",
		"@projectwallace/preset-oxlint": "^0.0.10",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.0.3",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.24.0",
		"publint": "^0.3.15",
		"tsdown": "^0.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.0.3"
	},
	"engines": {
		"node": ">=20.12.0",
		"pnpm": ">=11.0.0"
	},
	"packageManager": "pnpm@11.1.1",
	"pnpm": {
		"onlyBuiltDependencies": []
	},
	"issues": "https://github.com/projectwallace/format-css/issues"
}
